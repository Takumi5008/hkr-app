{
  "name": "インフラ管理",
  "short_name": "インフラ管理",
  "description": "HKR・シフト管理システム",
  "start_url": "/dashboard",
  "display": "standalone",
  "background_color": "#312e81",
  "theme_color": "#4338ca",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", ".m4a", ".mp3", ".wav", ".aac", ".mp4", ".caf"]
        }
      ]
    }
  }
}
